# ============================
# Maestro — Deterministic .gitignore
# ============================

# ---- OS Artifacts ----
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.Trash-*
.fseventsd
.Spotlight-V100
.TemporaryItems

# ---- Node / Expo ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.expo/
.expo-shared/
dist/
web-build/
*.tsbuildinfo

# ---- React Native ----
android/app/build/
ios/Pods/
ios/build/
*.xcworkspace
*.xcuserstate
*.xcuserdata/
*.pbxuser

# ---- Python ----
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
*.egg
build/
dist/
.venv/
venv/
.env
.env.*
pip-wheel-metadata/

# ---- FastAPI / Uvicorn ----
*.log
*.sqlite3

# ---- Agents ----
agents/**/__pycache__/
agents/**/logs/
agents/**/tmp/

# ---- Mongo / Redis ----
data/db/
data/redis/
dump/

# ---- Docker ----
docker/*.pid
docker/*.log
docker-compose.override.yml

# ---- VSCode ----
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# ---- JetBrains ----
.idea/

# ---- Testing ----
coverage/
.nyc_output/
pytest_cache/

# ---- Environment / Secrets ----
infra/env/*.env
infra/env/.env.*
*.secret
*.key
*.pem

# ---- Misc ----
.cache/
.parcel-cache/
.history/
